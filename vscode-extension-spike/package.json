{
  "name": "ireview-vscode-spike",
  "displayName": "Interactive Review (spike)",
  "description": "VS Code client for the interactive_review server.",
  "version": "0.1.49",
  "publisher": "petros",
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ireview",
          "title": "Interactive Review",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "ireview": [
        {
          "id": "ireview.annotations",
          "name": "Annotations",
          "type": "tree"
        }
      ]
    },
    "commands": [
      {
        "command": "ireview.openAnchor",
        "title": "Open Annotation",
        "category": "Interactive Review"
      },
      {
        "command": "ireview.deleteThread",
        "title": "Delete Thread",
        "category": "Interactive Review",
        "icon": "$(trash)"
      },
      {
        "command": "ireview.refresh",
        "title": "Refresh Annotations",
        "category": "Interactive Review",
        "icon": "$(refresh)"
      },
      {
        "command": "ireview.navigate",
        "title": "Navigate to Path",
        "category": "Interactive Review"
      },
      {
        "command": "ireview.gotoSymbol",
        "title": "Go to Symbol Definition",
        "category": "Interactive Review"
      },
      {
        "command": "ireview.copySlashCommand",
        "title": "Copy /interactive-review command",
        "category": "Interactive Review"
      },
      {
        "command": "ireview.reply",
        "title": "Ask Claude",
        "category": "Interactive Review",
        "enablement": "!commentIsEmpty"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "ireview.refresh",
          "when": "view == ireview.annotations",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "ireview.deleteThread",
          "when": "view == ireview.annotations && viewItem == annotation",
          "group": "inline"
        }
      ],
      "comments/commentThread/context": [
        {
          "command": "ireview.reply",
          "group": "inline",
          "when": "commentController == ireview.comments"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "prebuild": "node scripts/version.js",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import=tsx test/*.test.ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
