<idea-plugin>
    <id>com.petros.interactive-review-spike</id>
    <name>Interactive Review (spike)</name>
    <vendor>Petros Makris</vendor>

    <description><![CDATA[
        Spike: attach a gutter icon to line 1 of the right side of any two-side text diff.
        Clicking the icon pops an input dialog and logs the entered text.
    ]]></description>

    <idea-version since-build="242" until-build="243.*"/>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    <!-- Bundled GitHub plugin: lets us open the real PR diff view via
         GHPRProjectViewModel.openPullRequestDiff (with inline PR comments). -->
    <depends>org.jetbrains.plugins.github</depends>

    <extensions defaultExtensionNs="com.intellij">
        <diff.DiffExtension implementation="com.petros.ireview.SpikeDiffExtension"/>
        <editorFactoryListener implementation="com.petros.ireview.WorkingCopyAskGutter"/>
        <editorFactoryListener implementation="com.petros.ireview.WalkthroughGutter"/>
<projectService serviceImplementation="com.petros.ireview.ReviewSessionService"/>
        <applicationService serviceImplementation="com.petros.ireview.ShortcutPrefs"/>
        <statusBarWidgetFactory id="com.petros.ireview.statusbar"
                                implementation="com.petros.ireview.ReviewStatusBarWidgetFactory"/>
        <toolWindow id="Review Annotations"
                    anchor="right"
                    icon="/icons/annotation_yellow.svg"
                    factoryClass="com.petros.ireview.AnnotationsToolWindowFactory"/>
        <projectService serviceImplementation="com.petros.ireview.WalkthroughService"/>
        <toolWindow id="Walkthrough"
                    anchor="right"
                    icon="/icons/comment.svg"
                    factoryClass="com.petros.ireview.WalkthroughToolWindowFactory"/>
    </extensions>

    <actions>
        <action id="com.petros.ireview.PrettifyJsonStringAction"
                class="com.petros.ireview.PrettifyJsonStringAction"
                text="Prettify JSON String"
                description="Reformat the JSON inside the surrounding Java text block, preserving {{placeholders}}.">
            <add-to-group group-id="EditMenu" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <!-- Bind the macOS keymaps directly: a $default shortcut has its `control`
                 auto-translated to Cmd (⌘) on macOS, which landed on an already-taken
                 ⌥⇧⌘L. Declaring on the Mac keymaps keeps `control` literal → ⌃⌥⇧L. -->
            <keyboard-shortcut keymap="Mac OS X 10.5+" first-keystroke="control alt shift L"/>
            <keyboard-shortcut keymap="Mac OS X" first-keystroke="control alt shift L"/>
        </action>
        <action id="com.petros.ireview.ShowShortcutsAction"
                class="com.petros.ireview.ShowShortcutsAction"
                text="Show Shortcut Cheat-Sheet"
                description="Open an editable cheat-sheet of your keymap shortcuts.">
            <add-to-group group-id="HelpMenu" anchor="last"/>
            <!-- ⌃⌥⇧/ — literal control on the Mac keymaps so it stays Ctrl (not ⌘).
                 NOT ⌃⇧/: that is CommentByBlockComment in the "Mac OS X 10.5+" keymap.
                 ⌃⌥⇧/ is free and parallels this plugin's ⌃⌥⇧L (Prettify). -->
            <keyboard-shortcut keymap="Mac OS X 10.5+" first-keystroke="control alt shift SLASH"/>
            <keyboard-shortcut keymap="Mac OS X"       first-keystroke="control alt shift SLASH"/>
        </action>
    </actions>
</idea-plugin>
